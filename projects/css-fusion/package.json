{
  "name": "@dev.spot/css-fusion",
  "version": "0.0.1",
  "description": "A library for reusable SCSS components and TypeScript functionalities.",
  "main": "dist/styles-library/bundles/styles-library.umd.js",
  "style": "dist/styles-library/scss/main.scss",
  "types": "dist/styles-library/styles-library.d.ts",
  "scripts": {
    "build-scripts": "tsc -p ./tsconfig.lib.json"
  },
  "stylePreprocessorOptions": {
    "includePaths": [
      "./node_modules"
    ]
  },
  "sideEffects": false
}
